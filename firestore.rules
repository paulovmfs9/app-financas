rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validSubscriptionTypes() {
      return request.resource.data.plan in ['free', 'basic', 'standard', 'pro']
        && request.resource.data.subscriptionStatus in ['inactive', 'active', 'canceled']
        && (request.resource.data.subscriptionProvider == null || request.resource.data.subscriptionProvider in ['web', 'mercadopago', 'stripe', 'apple', 'google', 'revenuecat', 'manual'])
        && request.resource.data.subscriptionPrice is number
        && request.resource.data.subscriptionCurrency == 'BRL'
        && (request.resource.data.subscriptionExpiresAt == null || request.resource.data.subscriptionExpiresAt is number || request.resource.data.subscriptionExpiresAt is timestamp)
        && (request.resource.data.updatedAt is number || request.resource.data.updatedAt is timestamp);
    }

    function hasDefaultFreeSubscription() {
      return request.resource.data.plan in ['free', 'basic']
        && request.resource.data.subscriptionStatus == 'inactive'
        && request.resource.data.subscriptionProvider == null
        && request.resource.data.subscriptionPrice == 9.9
        && request.resource.data.subscriptionCurrency == 'BRL'
        && request.resource.data.subscriptionExpiresAt == null;
    }

    function subscriptionFieldsUnchanged() {
      return resource != null
        && request.resource.data.plan == resource.data.plan
        && request.resource.data.subscriptionStatus == resource.data.subscriptionStatus
        && request.resource.data.subscriptionProvider == resource.data.subscriptionProvider
        && request.resource.data.subscriptionPrice == resource.data.subscriptionPrice
        && request.resource.data.subscriptionCurrency == resource.data.subscriptionCurrency
        && request.resource.data.subscriptionExpiresAt == resource.data.subscriptionExpiresAt;
    }

    function validUserDoc(uid) {
      return request.resource.data.keys().hasOnly([
        'uid',
        'email',
        'name',
        'monthly_salary',
        'fixed_bills_total',
        'budget_cycle_start_day',
        'budget_cycle_end_day',
        'theme',
        'onboarded',
        'created_at',
        'plan',
        'subscriptionStatus',
        'subscriptionProvider',
        'subscriptionPrice',
        'subscriptionCurrency',
        'subscriptionExpiresAt',
        'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'uid',
        'email',
        'name',
        'monthly_salary',
        'fixed_bills_total',
        'budget_cycle_start_day',
        'budget_cycle_end_day',
        'theme',
        'onboarded',
        'created_at',
        'plan',
        'subscriptionStatus',
        'subscriptionProvider',
        'subscriptionPrice',
        'subscriptionCurrency',
        'subscriptionExpiresAt',
        'updatedAt'
      ])
      && request.resource.data.uid == uid
      && request.resource.data.email is string
      && request.resource.data.name is string
      && request.resource.data.monthly_salary is number
      && request.resource.data.fixed_bills_total is number
      && request.resource.data.budget_cycle_start_day is number
      && request.resource.data.budget_cycle_start_day >= 1
      && request.resource.data.budget_cycle_start_day <= 31
      && request.resource.data.budget_cycle_end_day is number
      && request.resource.data.budget_cycle_end_day >= 1
      && request.resource.data.budget_cycle_end_day <= 31
      && request.resource.data.theme in ['light', 'dark', 'system']
      && request.resource.data.onboarded is bool
      && request.resource.data.created_at is number
      && validSubscriptionTypes();
    }

    function validFixedBillDoc(uid) {
      return request.resource.data.keys().hasOnly([
        'user_id',
        'name',
        'amount',
        'due_day',
        'is_active',
        'installment_count',
        'installment_start_date',
        'installment_end_date',
        'created_at',
        'updated_at'
      ])
      && request.resource.data.keys().hasAll([
        'user_id',
        'name',
        'amount',
        'due_day',
        'is_active',
        'created_at',
        'updated_at'
      ])
      && request.resource.data.user_id == uid
      && request.resource.data.name is string
      && request.resource.data.amount is number
      && request.resource.data.amount > 0
      && request.resource.data.due_day is number
      && request.resource.data.due_day >= 1
      && request.resource.data.due_day <= 31
      && request.resource.data.is_active is bool
      && (!request.resource.data.keys().hasAny(['installment_count']) || (request.resource.data.installment_count is number && request.resource.data.installment_count >= 1 && request.resource.data.installment_count <= 120))
      && (!request.resource.data.keys().hasAny(['installment_start_date']) || request.resource.data.installment_start_date is number)
      && (!request.resource.data.keys().hasAny(['installment_end_date']) || request.resource.data.installment_end_date is number)
      && request.resource.data.created_at is number
      && request.resource.data.updated_at is number;
    }

    match /users/{uid} {
      allow read: if signedInAs(uid);
      allow create: if signedInAs(uid) && validUserDoc(uid) && hasDefaultFreeSubscription();
      allow update: if signedInAs(uid) && validUserDoc(uid) && (subscriptionFieldsUnchanged() || hasDefaultFreeSubscription());
      allow delete: if signedInAs(uid);

      match /expenses/{expenseId} {
        allow read: if signedInAs(uid);
        allow create, update, delete: if false;
      }

      match /fixedBills/{fixedBillId} {
        allow read: if signedInAs(uid);
        allow create, update: if signedInAs(uid) && validFixedBillDoc(uid);
        allow delete: if signedInAs(uid);
      }

      match /usage/{monthId} {
        allow read: if signedInAs(uid);
        allow create, update, delete: if false;
      }

      match /exports/{exportId} {
        allow read: if signedInAs(uid);
        allow create, update, delete: if false;
      }
    }

    match /paymentIntents/{paymentId} {
      allow read, write: if false;
    }
  }
}
